POSTGRES_DB=basiret_db
POSTGRES_USER=basiret_user
POSTGRES_PASSWORD=your_password_here
DATABASE_URL=postgresql://basiret_user:your_password_here@db:5432/basiret_db
REDIS_URL=redis://redis:6379/0
SECRET_KEY=your-secret-key-here
ENVIRONMENT=development
# Meta exposes TWO distinct app IDs in the same App dashboard:
#   META_APP_ID       — Facebook App ID, used for Graph API server-to-server
#                       admin calls (e.g. data-deletion callback).
#   INSTAGRAM_APP_ID  — Instagram product App ID, the ONLY value
#                       instagram.com/oauth/authorize accepts as client_id.
#                       Find it on the Instagram product page inside the App.
# META_APP_SECRET is the Instagram product's App Secret (Meta surfaces it
# under both names). Used for token exchange + the data-deletion HMAC.
META_APP_ID=your_facebook_app_id_here
INSTAGRAM_APP_ID=your_instagram_app_id_here
META_APP_SECRET=your_app_secret_here
INSTAGRAM_REDIRECT_URI=http://localhost:8000/api/v1/instagram/callback
INSTAGRAM_TEST_TOKEN=paste_your_token_here
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_CAPTION_MODEL=gpt-4o-mini
# RapidAPI — leave blank to use the bundled mock data on Competitors & Trends.
RAPIDAPI_KEY=
RAPIDAPI_INSTAGRAM_HOST=instagram-scraper-api2.p.rapidapi.com
# Cloudflare R2 — leave R2_ACCOUNT_ID blank to use the local /tmp fallback.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=basiret-media
R2_PUBLIC_URL=
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_INSIGHTS_PRICE_ID=price_your_insights_price_id_here
FRONTEND_URL=http://localhost:3000
