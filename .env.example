POSTGRES_DB=basiret_db
POSTGRES_USER=basiret_user
POSTGRES_PASSWORD=your_password_here
DATABASE_URL=postgresql://basiret_user:your_password_here@db:5432/basiret_db
REDIS_URL=redis://redis:6379/0
SECRET_KEY=your-secret-key-here
ENVIRONMENT=development
# Meta exposes TWO distinct app products in the same App dashboard, and
# each product has its OWN id AND its OWN secret. They are NOT interchangeable.
#
# Facebook product (App → Settings → Basic):
#   META_APP_ID        — Facebook App ID. For Graph API admin calls + the
#                        data-deletion callback HMAC.
#   META_APP_SECRET    — Facebook App Secret. Pairs with META_APP_ID.
#                        NOT used for Instagram OAuth; reserved for FB Graph
#                        server-to-server calls.
#
# Instagram product (App → Use Cases → API setup with Instagram Login):
#   INSTAGRAM_APP_ID     — Instagram App ID. ONLY value Instagram's OAuth
#                          endpoints accept as client_id.
#   INSTAGRAM_APP_SECRET — Instagram App Secret. ONLY value those endpoints
#                          accept as client_secret. Used for the short-token
#                          exchange (api.instagram.com/oauth/access_token)
#                          AND the long-lived exchange
#                          (graph.instagram.com/access_token, ig_exchange_token).
#
# Mixing them up: wrong client_id → "Invalid platform app". Wrong
# client_secret → "redirect_uri identical to the one you used in the OAuth
# dialog request" (misleading; it's actually a secret mismatch).
META_APP_ID=your_facebook_app_id_here
META_APP_SECRET=your_facebook_app_secret_here
INSTAGRAM_APP_ID=your_instagram_app_id_here
INSTAGRAM_APP_SECRET=your_instagram_app_secret_here
INSTAGRAM_REDIRECT_URI=http://localhost:8000/api/v1/instagram/callback
INSTAGRAM_TEST_TOKEN=paste_your_token_here
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_CAPTION_MODEL=gpt-4o-mini
# RapidAPI — leave blank to use the bundled mock data on Competitors & Trends.
RAPIDAPI_KEY=
RAPIDAPI_INSTAGRAM_HOST=instagram-scraper-api2.p.rapidapi.com
# Cloudflare R2 — leave R2_ACCOUNT_ID blank to use the local /tmp fallback.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=basiret-media
R2_PUBLIC_URL=
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_INSIGHTS_PRICE_ID=price_your_insights_price_id_here
FRONTEND_URL=http://localhost:3000
