#!/usr/bin/env bash
# Block pushes that fail strict TypeScript build.
#
# Why: production uses `tsc -b && vite build`, which is stricter than
# `tsc --noEmit` (it fails on noUnusedLocals / noUnusedParameters and
# checks the entire project graph). Catching it locally avoids a CI
# rollback round-trip. See README for setup.
#
# Skip with: git push --no-verify

set -e

# Resolve repo root regardless of where the hook is invoked from.
REPO_ROOT="$(git rev-parse --show-toplevel)"
FRONTEND_DIR="$REPO_ROOT/frontend"

if [ ! -d "$FRONTEND_DIR" ]; then
  echo "pre-push: frontend/ not found, skipping tsc check"
  exit 0
fi

echo "pre-push: running 'npx tsc -b' in frontend/ ..."

cd "$FRONTEND_DIR"
if ! npx --no-install tsc -b 2>&1; then
  echo
  echo "pre-push: TypeScript build failed. Push blocked."
  echo "         Fix the errors above, or override with: git push --no-verify"
  exit 1
fi

echo "pre-push: tsc -b passed."
exit 0
